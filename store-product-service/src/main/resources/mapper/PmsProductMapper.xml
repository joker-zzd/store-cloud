<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.store.mapper.PmsProductMapper">

    <resultMap id="BaseResultMap" type="com.store.domain.PmsProduct">
            <id property="id" column="id" />
            <result property="brandId" column="brand_id" />
            <result property="categoryId" column="category_id" />
            <result property="name" column="name" />
            <result property="pic" column="pic" />
            <result property="productSn" column="product_sn" />
            <result property="publishStatus" column="publish_status" />
            <result property="newStatus" column="new_status" />
            <result property="recommendStatus" column="recommend_status" />
            <result property="sort" column="sort" />
            <result property="price" column="price" />
            <result property="description" column="description" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,brand_id,category_id,name,pic,product_sn,
        publish_status,new_status,recommand_status,sort,price,
        description,create_time,update_time
    </sql>
</mapper>
